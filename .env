# Environment variables for PhysioScan AI
# Example values, update as needed for your deployment

# Server
PORT=3000

# Demo/Mock Mode (set to true to use mock data instead of real API)
DEMO_MODE=true

# Database (example, update if using a real DB)
DB_HOST=localhost
DB_PORT=5432
DB_USER=physioscan_user
DB_PASS=yourpassword
DB_NAME=physioscan_db

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# AI Service API Key (for Gemini/Google GenAI)
GEMINI_API_KEY=AIzaSyAq_rCniw2t5j0BvJUO-htMnppo-K0wqe8
AI_API_KEY=AIzaSyAq_rCniw2t5j0BvJUO-htMnppo-K0wqe8
VITE_GEMINI_API_KEY=AIzaSyAq_rCniw2t5j0BvJUO-htMnppo-K0wqe8
# Email (for notifications, if used)
EMAIL_FROM=no-reply@physioscan.edu

